#!/usr/bin/env bash
# Fake ffmpeg for integration tests.
# Three modes:
# 1. Frame extraction: -frames:v 1 → writes a tiny fake JPEG to the output path
# 2. Legacy concat demuxer: -f concat → writes a fake MP4 to the output path
# 3. Concat filter graph: -filter_complex → writes a fake MP4 to the output path

out="${!#}"

if [[ " $* " == *" -filter_complex "* ]]; then
    printf 'fake-mp4\n' > "$out"
    exit 0
fi

if [[ " $* " == *" -f concat "* ]]; then
    printf 'fake-mp4\n' > "$out"
    exit 0
fi

if [[ " $* " == *" -frames:v 1 "* ]]; then
    printf '\xff\xd8\xff\xe0fakejpeg\xff\xd9' > "$out"
    exit 0
fi

echo "fake ffmpeg: unexpected args: $*" >&2
exit 1
